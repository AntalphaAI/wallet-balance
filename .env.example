PORT=3000
REDIS_URL=redis://127.0.0.1:6379

# RPC for name resolution
ETH_RPC_URL=https://ethereum-rpc.publicnode.com
BNB_RPC_URL=https://bsc-rpc.publicnode.com

# Tokenview（可选）：不填 TOKENVIEW_API_KEY 时，网关仅使用公网可查数据
TOKENVIEW_BASE_URL=https://services.tokenview.io
TOKENVIEW_API_KEY=
ENABLE_FALLBACK_PROVIDER=true
TOKENVIEW_PROBE_IF_NO_PATH=false

# 有 Key 时建议按套餐填写可用模板，需包含 {address}，例如：
# TOKENVIEW_MULTI_CHAIN_PATH=/vipapi/eth/address/tokenbalance/{address}
TOKENVIEW_MULTI_CHAIN_PATH=

# 可选：记忆文件路径（默认 server 同目录 remembered-addresses.json）
# MEMORY_STORE_PATH=
