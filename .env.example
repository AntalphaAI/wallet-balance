PORT=3000
REDIS_URL=redis://127.0.0.1:6379

# RPC for ENS / .bnb resolution
ETH_RPC_URL=https://ethereum-rpc.publicnode.com
BNB_RPC_URL=https://bsc-rpc.publicnode.com

# MCP (Streamable HTTP + SSE): multi-chain balances via tool wallet-balance-query
MCP_SKILLS_URL=https://mcp-skills.ai.antalpha.com/mcp
MCP_TOOL_NAME=wallet-balance-query
# Optional Bearer token if your deployment requires auth
MCP_API_KEY=
# Set false to skip MCP and use public providers only for EVM; non-EVM requires MCP
ENABLE_MCP=true
# When an EVM MCP query fails, fall back to public RPC / Blockstream / CoinGecko
ENABLE_FALLBACK_PROVIDER=true
# Bound MCP response body size (characters) to limit memory use
MAX_MCP_RESPONSE_CHARS=12000000
# Max token rows read from MCP payload before grouping (defense in depth)
MCP_MAX_TOKEN_ROWS=50000

# Optional: path for remembered-addresses.json
# MEMORY_STORE_PATH=
